# Example environment file for backups (systemd EnvironmentFile=...)

# Container name from docker-compose.yml (container_name: studio-mariadb)
MARIADB_CONTAINER_NAME=studio-mariadb

# DB credentials for mariadb-dump inside the container
DB_NAME=resolution_bingo
DB_USER=root
DB_PASSWORD=root

# Where to write backups on the Ubuntu Server host
BACKUP_DIR=/var/backups/resolution-bingo

# Keep backups for N days
BACKUP_RETENTION_DAYS=14
